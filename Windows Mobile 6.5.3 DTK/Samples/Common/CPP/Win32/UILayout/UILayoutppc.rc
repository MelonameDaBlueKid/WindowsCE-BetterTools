// Menu
//

IDR_MENU MENU 
BEGIN
    MENUITEM "Exit",                        ID_EXIT
    POPUP "Menu"
    BEGIN
        MENUITEM "Demo 1",                      ID_DEMO1
        MENUITEM "Demo 2",                      ID_DEMO2
        MENUITEM "Demo 3",                      ID_DEMO3
    END
END

IDR_DIALOG MENU 
BEGIN
    MENUITEM "Done",                        IDOK
END


