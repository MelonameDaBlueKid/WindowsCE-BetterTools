STRINGTABLE 
BEGIN
    IDS_APP_TITLE           "UILayout"
    IDC_UILAYOUT            "UILAYOUT"
    IDS_EXIT                "Exit"
    IDS_DONE                "Done"
    IDS_MENU                "Menu"
    IDS_INSTRUCTIONS        "This is a docked control. Press Menu to see more ScreenLib demos.\r\n\r\nDemo 1 shows controls docked to various edges of the screen.\r\n\r\nDemo 2 shows how to stretch controls to utilize maximum screen space.\r\n\r\nDemo 3 shows a more complex UI by aligning buttons to the right of a stretchable listbox control."
END

