/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_DEMO1 DIALOG  0, 0, 95, 129
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Demo 1"
FONT 8, "MS Shell Dlg"
BEGIN
    LISTBOX         IDC_LIST1,7,7,48,57,LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    LISTBOX         IDC_LIST2,7,82,48,40,LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
END

IDD_DEMO2 DIALOG  0, 0, 88, 99
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Demo 2"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Full name:",IDC_STATIC1,7,6,34,8
    EDITTEXT        IDC_EDIT1,7,16,40,14,ES_AUTOHSCROLL
    LTEXT           "Phone number:",IDC_STATIC2,7,36,50,8
    EDITTEXT        IDC_EDIT2,7,46,40,14,ES_AUTOHSCROLL
    LTEXT           "Notes:",IDC_STATIC3,7,68,22,8
    EDITTEXT        IDC_EDIT3,7,78,40,14,ES_MULTILINE | ES_AUTOHSCROLL | ES_WANTRETURN | WS_VSCROLL
END

IDD_DEMO3 DIALOG  0, 0, 137, 102
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Demo 3"
FONT 8, "MS Shell Dlg"
BEGIN
    LTEXT           "Themes:",IDC_STATIC1,7,5,66,8
    CONTROL         "Use this picture as a background:",IDC_CHECK1,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,17,123,10
    EDITTEXT        IDC_EDIT1,7,32,40,14,ES_AUTOHSCROLL
    LISTBOX         IDC_LIST1,7,53,48,40,LBS_SORT | LBS_NOINTEGRALHEIGHT | WS_VSCROLL | WS_TABSTOP
    PUSHBUTTON      "Beam",IDC_BUTTON1,63,53,50,14
    PUSHBUTTON      "Delete",IDC_BUTTON2,63,69,50,14
END


