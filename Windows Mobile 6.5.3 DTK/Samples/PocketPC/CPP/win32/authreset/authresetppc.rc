STRINGTABLE 
BEGIN
    IDS_SETUP               "To enable device recovery if you lose or forget your information, we will now save a backup recovery key."
    IDS_REQUEST             "To recover your device if you have lost or forgotten your information, we will retrieve the backup recovery key."
    IDS_SETUP_RESULT_OK     "Backup recovery key was successfully saved."
    IDS_REQUEST_RESULT_OK   "The backup recovery key was retrieved successfully."
    IDS_SETUP_ERROR_GENERIC "Failed to save backup recovery key."
    IDS_REQUEST_ERROR_GENERIC 
                            "The backup recovery key could not be retrieved."
    IDS_ERROR_UNEXPECTED    "An unexpected system error occured."
    IDS_ERROR_ACCESSDENIED  "Invalid username and/or password."
    IDS_ERROR_ABORT         "Cancelled by user."
    IDS_ERROR_NETWORK       "Could not establish a network connection."
    IDS_ERROR_UNREACHABLE   "Could not connect."
END

