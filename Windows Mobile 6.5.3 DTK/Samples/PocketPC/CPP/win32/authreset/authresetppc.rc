/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ERRORDLG_PPC_PORTRAIT DIALOG  0, 0, 156, 177
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_ABOVESTARTUP
CAPTION "Error condition simulation"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL         "Success",IDC_SIMULDLG_SUCCESS,"Button",BS_AUTORADIOBUTTON | WS_GROUP,7,7,41,10
    CONTROL         "Failure",IDC_SIMULDLG_FAILURE,"Button",BS_AUTORADIOBUTTON,7,22,37,10
    COMBOBOX        IDC_ERRORCODE_COMBO,17,50,132,30,CBS_DROPDOWN | WS_DISABLED | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Error Code:",IDC_ERRORCODE_STATIC,17,37,132,8,WS_DISABLED
END

IDD_PASSCODEDLG_PPC_PORTRAIT DIALOG  0, 0, 156, 177
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_ABOVESTARTUP
CAPTION "Passcode simulation"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL         "Success",IDC_SIMULDLG_SUCCESS,"Button",BS_AUTORADIOBUTTON | WS_GROUP,7,7,41,10
    CONTROL         "Failure",IDC_SIMULDLG_FAILURE,"Button",BS_AUTORADIOBUTTON,7,51,37,10
    COMBOBOX        IDC_ERRORCODE_COMBO,17,77,132,30,CBS_DROPDOWN | WS_DISABLED | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Error Code:",IDC_ERRORCODE_STATIC,17,65,132,8,WS_DISABLED
    LTEXT           "Passcode:",IDC_PASSCODE_STATIC,17,21,132,8
    EDITTEXT        IDC_PASSCODE_EDIT,17,33,132,14,ES_AUTOHSCROLL | ES_READONLY
END


