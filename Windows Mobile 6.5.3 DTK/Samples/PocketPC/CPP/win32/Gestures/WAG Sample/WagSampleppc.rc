CAPTION "About WAG Sample"
FONT 8, "MS Sans Serif"
BEGIN
    ICON            IDC_WAG_SAMPLE,IDC_STATIC_1,12,12,20,20,SS_REALSIZEIMAGE
    LTEXT           "WAG Sample Version 1.0",IDC_STATIC_2,12,36,137,8,SS_NOPREFIX
    LTEXT           "Copyright (C) 2009",IDC_STATIC_3,12,48,66,8
END

