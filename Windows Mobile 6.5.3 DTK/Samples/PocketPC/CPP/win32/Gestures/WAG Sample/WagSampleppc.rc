IDD_WAG_CONFIG DIALOG  0, 0, 140, 125
STYLE DS_SETFONT | DS_FIXEDSYS | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Configure"
FONT 8, "MS Shell Dlg"
BEGIN
    CONTROL         "Support Pan",IDC_PAN_ENABLED,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,7,55,10
    CONTROL         "Support Scroll",IDC_SCROLL_ENABLED,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,17,60,10
    CONTROL         "Lock Axis",IDC_LOCK_AXIS,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,27,45,10
    CONTROL         "Use WM_SCROLL",IDC_USE_WM_SCROLL,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,37,71,10
    CONTROL         "HScroll",IDC_HSCROLL,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,47,37,10
    CONTROL         "VScroll",IDC_VSCROLL,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,7,57,37,10
    LTEXT           "Horizontal extent:",IDC_STATIC,7,73,70,8
    EDITTEXT        IDC_HORZEXTENT,82,71,40,14,ES_RIGHT | ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Vertical extent:",IDC_STATIC,7,89,69,8
    EDITTEXT        IDC_VERTEXTENT,82,87,40,14,ES_RIGHT | ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "Item size:",IDC_STATIC,7,104,35,8
    EDITTEXT        IDC_CXITEM,47,102,23,14,ES_RIGHT | ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "x",IDC_STATIC,75,106,10,8
    EDITTEXT        IDC_CYITEM,85,102,23,14,ES_RIGHT | ES_AUTOHSCROLL | ES_NUMBER
END


