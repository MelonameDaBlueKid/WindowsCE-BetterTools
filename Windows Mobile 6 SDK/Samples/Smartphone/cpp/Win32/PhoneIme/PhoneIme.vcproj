				PreprocessorDefinitions="_WIN32_WCE=$(CEVER);UNDER_CE=$(CEVER);_DEBUG;DEBUG;_WINDOWS;_USRDLL;PHONEIME_EXPORTS;$(ARCHFAM);$(_ARCHFAM_);_UNICODE;UNICODE"
