				DelayLoadDLLs="$(NOINHERIT)"
				GenerateDebugInformation="true"
				ProgramDatabaseFile="$(OutDir)/PhoneIme.pdb"
				SubSystem="0"
				StackReserveSize="65536"
				ImportLibrary="$(OutDir)/PhoneIme.lib"
