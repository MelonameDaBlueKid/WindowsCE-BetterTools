IDM_MAINMENU SHMENUBAR MOVEABLE PURE 
BEGIN
    IDM_MAINMENU, 2,
    I_IMAGENONE, IDM_NEWITEM, TBSTATE_ENABLED, TBSTYLE_AUTOSIZE, IDS_CAP_NEW, 
    0, NOMENU,
    I_IMAGENONE, IDM_POOMCAT, TBSTATE_ENABLED, 
    TBSTYLE_DROPDOWN | TBSTYLE_AUTOSIZE, IDS_CAP_MODE, 0, 1,
END

IDM_NEWITEMMENU SHMENUBAR MOVEABLE PURE 
BEGIN
    IDM_NEWITEMMENU, 2,
    I_IMAGENONE, IDM_OK, TBSTATE_ENABLED, TBSTYLE_AUTOSIZE, IDS_OK, 0, 
    NOMENU,
