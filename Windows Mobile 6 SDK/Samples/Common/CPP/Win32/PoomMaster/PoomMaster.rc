    IDS_CAP_CANCEL, 0, NOMENU,
END


/////////////////////////////////////////////////////////////////////////////
//
// Menubar
//

IDM_MAINMENU MENU DISCARDABLE 
BEGIN
    MENUITEM "New",                         IDM_NEWITEM
    POPUP "Mode"
    BEGIN
        MENUITEM "Tasks",                       IDM_MODE_TASKS
        MENUITEM "Contacts",                    IDM_MODE_CONTACTS
        MENUITEM "Calendar",                    IDM_MODE_CALENDAR
        MENUITEM "Quit",                        IDM_QUIT
    END
END

IDM_NEWITEMMENU MENU DISCARDABLE 
BEGIN
    MENUITEM "OK",                          IDM_OK
    MENUITEM "Cancel",                      IDM_CANCEL
END


/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_MAIN DIALOG DISCARDABLE  0, 0, 171, 171
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "POOMmaster"
FONT 8, "System"
BEGIN
END

IDD_NEWTASK DIALOG DISCARDABLE  0, 0, 147, 177
STYLE WS_POPUP | WS_CAPTION
CAPTION "New Task"
FONT 8, "System"
BEGIN
    EDITTEXT        IDC_TASKDESC,4,16,90,12,ES_AUTOHSCROLL
    LISTBOX         IDC_IMPORTANCE,4,42,80,12,LBS_SORT | 
                    LBS_NOINTEGRALHEIGHT | WS_TABSTOP
    LTEXT           "Task Description",IDC_STATIC,4,4,90,12
    LTEXT           "Importance",IDC_STATIC,4,28,90,12
END

IDD_NEWCONTACT DIALOG DISCARDABLE  0, 0, 116, 158
STYLE WS_POPUP | WS_CAPTION
CAPTION "New Contact"
FONT 8, "System"
BEGIN
    EDITTEXT        IDC_FIRSTNAME,4,14,80,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_LASTNAME,4,36,80,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_PHONENUMBER,4,58,80,14,ES_AUTOHSCROLL | ES_NUMBER
    LTEXT           "First Name",IDC_STATIC1,4,4,80,10
    LTEXT           "Last Name",IDC_STATIC,4,26,80,10
    LTEXT           "Phone Number",IDC_STATIC,4,48,80,10
END

IDD_NEWAPPNTMNT DIALOG DISCARDABLE  0, 0, 104, 161
STYLE WS_POPUP | WS_CAPTION
CAPTION "New Appointment"
FONT 8, "System"
BEGIN
    CONTROL         "DateTimePicker1",IDC_DAYMONTHPICKER,"SysDateTimePick32",
                    WS_TABSTOP,4,16,60,12
    CONTROL         "DateTimePicker2",IDC_TIMEPICKER,"SysDateTimePick32",
                    DTS_UPDOWN | DTS_APPCANPARSE | WS_BORDER | WS_TABSTOP | 
                    0x8,4,40,60,12
    LTEXT           "Date",IDC_STATIC,4,4,54,10
    LTEXT           "Time",IDC_STATIC,4,28,45,10
    EDITTEXT        IDC_DESC,4,62,89,12,ES_AUTOHSCROLL
    LTEXT           "Description",IDC_STATIC,4,52,90,10
END


