			<Tool
				Name="VCPreLinkEventTool"
			/>
			<Tool
				Name="VCLinkerTool"
				UseUnicodeResponseFiles="false"
				AdditionalOptions=" /subsystem:windowsce,5.01 /machine:THUMB"
				AdditionalDependencies="aygshell.lib coredll.lib commctrl.lib"
				OutputFile="$(OutDir)/Spintest.exe"
				LinkIncremental="1"
				IgnoreAllDefaultLibraries="false"
				IgnoreDefaultLibraryNames="oldnames.lib"
				DelayLoadDLLs="$(NOINHERIT)"
				GenerateDebugInformation="true"
				ProgramDatabaseFile="$(OutDir)/Spintest.pdb"
				SubSystem="0"
				StackReserveSize="65536"
