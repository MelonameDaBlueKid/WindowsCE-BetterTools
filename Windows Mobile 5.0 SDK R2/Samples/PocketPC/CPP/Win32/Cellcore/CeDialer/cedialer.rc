IDD_CEDIALER DIALOGEX 0, 0, 136, 162
STYLE DS_CENTER | WS_POPUP | WS_BORDER
EXSTYLE 0x80000000L
FONT 8, "Tahoma"
BEGIN
    EDITTEXT        IDC_PHONENUM,32,10,72,12,ES_AUTOHSCROLL
    PUSHBUTTON      "Select Line",IDC_SELECTLINE,26,102,42,12,BS_CENTER | 
                    BS_VCENTER | BS_MULTILINE
    PUSHBUTTON      "Dial",IDC_DIAL,68,102,42,12
    PUSHBUTTON      "1",IDC_BUTTON1,32,22,24,20
    PUSHBUTTON      "ABC\n2",IDC_BUTTON2,56,22,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "DEF\n3",IDC_BUTTON3,80,22,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "GHI\n4",IDC_BUTTON4,32,42,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "JKL\n5",IDC_BUTTON5,56,42,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "MNO\n6",IDC_BUTTON6,80,42,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "PRS\n7",IDC_BUTTON7,32,62,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "TUV\n8",IDC_BUTTON8,56,62,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "WXY\n9",IDC_BUTTON9,80,62,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "*",IDC_BUTTONSTAR,32,82,24,20
    PUSHBUTTON      "OPER\n0",IDC_BUTTON0,56,82,24,20,BS_CENTER | BS_VCENTER | 
                    BS_MULTILINE
    PUSHBUTTON      "#",IDC_BUTTONPOUND,80,82,24,20
    LTEXT           "Enter Phone Number:",IDC_STATIC,32,0,72,10
END

IDD_CONNECTUSING DIALOG DISCARDABLE  0, 0, 135, 87
STYLE DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION
FONT 8, "Tahoma"
BEGIN
    LTEXT           "Line:",IDC_STATIC,6,25,78,8
    LTEXT           "Address:",IDC_STATIC,6,53,78,8
    COMBOBOX        IDC_LISTLINES,6,36,122,83,CBS_DROPDOWN | CBS_SORT | 
                    WS_VSCROLL | WS_TABSTOP
    COMBOBOX        IDC_LISTADDRESSES,6,64,122,88,CBS_DROPDOWN | CBS_SORT | 
                    WS_VSCROLL | WS_TABSTOP
    LTEXT           "Connect Using:",IDC_STATIC,6,10,50,8
END

IDD_DIALING DIALOG DISCARDABLE  0, 0, 159, 95
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION
FONT 8, "Tahoma"
BEGIN
    PUSHBUTTON      "Hang Up",IDCANCEL,55,78,50,14
    CTEXT           "",IDC_PHONENUM,6,23,146,8
    CTEXT           "Phone Number:",IDC_STATIC,6,10,146,8
    CTEXT           "",IDC_STATUSMESSAGE,6,52,146,8
    CTEXT           "Current Status:",IDC_STATIC,6,41,146,8
END

IDD_CEDIALER_SP DIALOG DISCARDABLE  0, 0, 148, 134
