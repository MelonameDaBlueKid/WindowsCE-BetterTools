#include <windows.h>
#include <commctrl.h>
#include <aygshell.h>
#include "IDs.h"

IDD_MEDICALHISTORY DIALOG DISCARDABLE 0, 0, 160, 212
STYLE WS_POPUP | WS_SYSMENU
EXSTYLE WS_EX_CAPTIONOKBTN | WS_EX_NODRAG | WS_TABSTOP
CAPTION "Medical History"
BEGIN
    LTEXT           "Health Insurance Provider:",IDC_HEALTHINSURANCE_LABEL,8,8,100,14
    EDITTEXT        IDC_HEALTHINSURANCE_EDITBOX,8,22,100,14,ES_AUTOHSCROLL
    LTEXT           "Blood Group:",IDC_BLOODGROUP_LABEL,8,40,100,14
    EDITTEXT        IDC_BLOODGROUP_EDITBOX,8,54,100,14,ES_AUTOHSCROLL
    LTEXT           "Blood Pressure Level:",IDC_BLOODPRESSURE_LABEL,8,72,100,14
    EDITTEXT        IDC_BLOODPRESSURE_EDITBOX,8,86,100,14,ES_AUTOHSCROLL
    LTEXT           "Allergies:",IDC_ALLERGIES_LABEL,8,104,100,14
    EDITTEXT        IDC_ALLERGIES_EDITBOX,8,118,100,14,ES_AUTOHSCROLL
END

