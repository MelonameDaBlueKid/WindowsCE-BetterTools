IDM_MAIN_MENU MENU DISCARDABLE 
BEGIN
    //POPUP "File"
    //BEGIN
    //    MENUITEM "Exit",                       IDM_FILE_EXIT
    //END
    POPUP "ObjStore"
    BEGIN
        MENUITEM "Create Database",            IDM_CREATEDB
        MENUITEM "Delete Database",            IDM_DELETEDB
        MENUITEM "Modify Indexes",             IDM_INDEXDB
        MENUITEM "Use Indexes",                IDM_USEINDEXES
        MENUITEM "Storage Space",              ID_OBJECTSTORE_STORAGESPACE
    END
    POPUP "Help"
    BEGIN
        MENUITEM "About...",                   IDM_HELP_ABOUT
    END
END


