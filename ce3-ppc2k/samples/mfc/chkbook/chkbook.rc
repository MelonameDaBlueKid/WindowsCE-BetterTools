/////////////////////////////////////////////////////////////////////////////
//
// Icon
//

// Icon with lowest ID value placed first to ensure application icon
// remains consistent on all systems.
IDR_MAINFRAME           ICON    DISCARDABLE     "res\\chkbook.ico"
IDR_CHKBOOTYPE          ICON    DISCARDABLE     "res\\ChkBkDoc.ico"

/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU PRELOAD DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "&New...\tCtrl+N",             ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Commit Check",               ID_EDIT_COMMIT
        MENUITEM SEPARATOR
        MENUITEM "&New Check",                  ID_EDIT_NEW_CHECK
        MENUITEM SEPARATOR
        MENUITEM "Ne&xt Check",                 ID_NEXT_CHECK
        MENUITEM "&Prev Check",                 ID_PREV_CHECK
    END
    POPUP "&View"
    BEGIN
        MENUITEM "&Check",                      ID_VIEW_CHECK
        MENUITEM "&Book",                       ID_VIEW_BOOK
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About...",                   ID_APP_ABOUT
    END
END




/////////////////////////////////////////////////////////////////////////////
//
// Accelerator
//

IDR_MAINFRAME ACCELERATORS PRELOAD MOVEABLE PURE 
BEGIN
    "C",            ID_EDIT_COPY,           VIRTKEY, CONTROL, NOINVERT
    "N",            ID_FILE_NEW,            VIRTKEY, CONTROL, NOINVERT
    "O",            ID_FILE_OPEN,           VIRTKEY, CONTROL, NOINVERT
    "V",            ID_EDIT_PASTE,          VIRTKEY, CONTROL, NOINVERT
    "X",            ID_EDIT_CUT,            VIRTKEY, CONTROL, NOINVERT
    "Z",            ID_EDIT_UNDO,           VIRTKEY, CONTROL, NOINVERT
END


/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOG DISCARDABLE  0, 0, 140, 45
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CAPTIONOKBTN
CAPTION "About Chkbook"
FONT 8, "Tahoma"
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,13,10,21,20
    LTEXT           "Chkbook",IDC_STATIC,51,10,79,8,SS_NOPREFIX
    LTEXT           "Copyright © 2000",IDC_STATIC,51,22,78,8
END

IDD_CHECK DIALOG DISCARDABLE  0, 0, 322, 112
STYLE WS_CHILD
FONT 8, "Tahoma"
BEGIN
    EDITTEXT        IDC_DATE,257,17,54,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_PAYTO,39,36,195,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_AMOUNTNUM,257,36,54,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_MEMO,39,92,147,12,ES_AUTOHSCROLL
    RTEXT           "Date:",IDC_STATIC,229,19,22,9
    RTEXT           "$",IDC_STATIC,241,39,11,9
    LTEXT           "Pay To:",IDC_STATIC,6,39,28,9
    RTEXT           "",IDC_AMOUNTTEXT,14,53,295,32
    LTEXT           "Memo:",IDC_STATIC,6,95,23,9
    RTEXT           "#",IDC_STATIC,241,5,10,9
    LTEXT           "Number",IDC_CHECKNO,259,5,47,9
END

IDD_CHECK_PSPC DIALOG DISCARDABLE  0, 0, 150, 120
STYLE WS_CHILD
FONT 8, "Tahoma"
BEGIN
    EDITTEXT        IDC_DATE,113,17,32,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_PAYTO,0,36,90,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_AMOUNTNUM,113,36,32,12,ES_AUTOHSCROLL
    EDITTEXT        IDC_MEMO,0,90,90,12,ES_AUTOHSCROLL
    RTEXT           "Date:",IDC_STATIC,85,19,22,9
    RTEXT           "$",IDC_STATIC,97,39,11,9
    LTEXT           "Pay To:",IDC_STATIC,1,25,28,9
    LTEXT           "",IDC_AMOUNTTEXT,1,52,144,24
    LTEXT           "Memo:",IDC_STATIC,3,79,23,9
    RTEXT           "#",IDC_STATIC,97,5,10,9
    LTEXT           "Number",IDC_CHECKNO,115,5,27,9
END


