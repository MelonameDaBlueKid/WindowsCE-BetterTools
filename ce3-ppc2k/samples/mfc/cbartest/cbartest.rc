/////////////////////////////////////////////////////////////////////////////
//
// Bitmap
//

IDR_MAINFRAME           BITMAP  DISCARDABLE     "cbartest.bmp"

/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOGEX 0, 0, 140, 45
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CAPTIONOKBTN
CAPTION "About Cbartest"
FONT 8, "Tahoma"
BEGIN
    LTEXT           "Cbartest ",IDC_STATIC,47,9,74,8
    LTEXT           "Copyright © 2000",IDC_STATIC,47,22,66,8
    ICON            IDR_MAINFRAME,IDC_STATIC,13,10,20,20
END


/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                       ID_FILE_EXIT
    END
    POPUP "&Options"
    BEGIN
        MENUITEM "&Combo box",                  ID_OPTIONS_COMBO
        MENUITEM "&Toolbar",                    ID_OPTIONS_TOOLBAR
#if !(defined(_WIN32_WCE_PSPC) && (_WIN32_WCE >= 300))
        MENUITEM SEPARATOR
        MENUITEM "&Help button",                ID_OPTIONS_HELP
        MENUITEM "&OK button",                  ID_OPTIONS_OK			
#endif // _WIN32_WCE_PSPC
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About CBARTEST...",          ID_APP_ABOUT
    END
END


/////////////////////////////////////////////////////////////////////////////
//
// DESIGNINFO
//

