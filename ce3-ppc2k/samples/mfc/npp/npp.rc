IDD_ABOUTBOX DIALOG DISCARDABLE  0, 0, 140, 45
#if defined(_WIN32_WCE_PSPC) && (_WIN32_WCE >= 300)
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
#else
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
#endif // _WIN32_WCE_PSPC
EXSTYLE WS_EX_CAPTIONOKBTN
CAPTION "About Npp"
FONT 8, "Tahoma"
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,16,9,21,20
    LTEXT           "Npp",IDC_STATIC,48,9,65,8
    LTEXT           "Copyright © 2000",IDC_STATIC,48,22,81,8
END

IDD_GOTO DIALOG DISCARDABLE  0, 0, 149, 51
#if defined(_WIN32_WCE_PSPC) && (_WIN32_WCE >= 300)
STYLE WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
#else
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
#endif // _WIN32_WCE_PSPC
CAPTION "Go To"
FONT 8, "Tahoma"
BEGIN
    EDITTEXT        IDC_GOTO_LINE,7,17,134,13,ES_AUTOHSCROLL
#if defined(_WIN32_WCE_PSPC) && (_WIN32_WCE >= 300)
    DEFPUSHBUTTON   "Go To",IDOK,50,35,50,14
    LTEXT           "Line:",IDC_STATIC,7,5,25,8
	CONTROL			"",-1,WC_SIPPREF,NOT WS_VISIBLE,-10,-10,5,5
#else
    DEFPUSHBUTTON   "&Go To",IDOK,50,35,50,14
    LTEXT           "&Line:",IDC_STATIC,7,5,25,8
#endif // _WIN32_WCE
END

IDD_FIND DIALOG DISCARDABLE  0, 0, 158, 73
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
CAPTION "Find"
FONT 8, "Tahoma"
BEGIN
    CONTROL         "Match &Case",IDC_CHECK1,"Button",BS_AUTOCHECKBOX | 
                    WS_TABSTOP,92,52,57,10
    CONTROL         "&Up",IDC_RADIO1,"Button",BS_AUTORADIOBUTTON | WS_GROUP | 
                    WS_TABSTOP,9,37,29,10
    CONTROL         "&Down",IDC_RADIO2,"Button",BS_AUTORADIOBUTTON | 
                    WS_TABSTOP,9,51,39,10
    DEFPUSHBUTTON   "&Find Next",ID_EDIT_FIND_NEXT,92,29,60,14,WS_GROUP
    GROUPBOX        "Direction",IDC_STATIC,4,26,77,38
    LTEXT           "Fi&nd What:",IDC_STATIC,5,9,51,8
    EDITTEXT        IDC_EDIT1,59,7,93,14,ES_AUTOHSCROLL
END


