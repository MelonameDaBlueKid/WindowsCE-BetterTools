/////////////////////////////////////////////////////////////////////////////
//
// Menu
//

IDR_MAINFRAME MENU PRELOAD DISCARDABLE 
BEGIN
#if defined(_WIN32_WCE_PSPC) && (_WIN32_WCE >= 212)
    POPUP "Edit"
    BEGIN
        MENUITEM "Undo",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cut",                ID_EDIT_CUT
        MENUITEM "Copy",               ID_EDIT_COPY
        MENUITEM "Paste",              ID_EDIT_PASTE
        MENUITEM "Clear"               ID_EDIT_CLEAR
        MENUITEM SEPARATOR
		MENUITEM "Select All"          ID_EDIT_SELECT_ALL
        MENUITEM SEPARATOR
        MENUITEM "Find...",            ID_EDIT_FIND
        MENUITEM "Replace...",         ID_EDIT_REPLACE
        MENUITEM "Go To...",           ID_EDIT_GOTO
    END
    POPUP "Tools"
    BEGIN
        MENUITEM "Save As...",                 ID_FILE_SAVE_AS
    END
#else
    POPUP "&File"
    BEGIN
        MENUITEM "&New...\tCtrl+N",             ID_FILE_NEW
        MENUITEM "&Open...\tCtrl+O",            ID_FILE_OPEN
        MENUITEM "&Save\tCtrl+S",               ID_FILE_SAVE
        MENUITEM "Save &As...",                 ID_FILE_SAVE_AS
        MENUITEM "&Print\tCtrl+P",              ID_FILE_PRINT
        MENUITEM SEPARATOR
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Edit"
    BEGIN
        MENUITEM "&Undo\tCtrl+Z",               ID_EDIT_UNDO
        MENUITEM SEPARATOR
        MENUITEM "Cu&t\tCtrl+X",                ID_EDIT_CUT
        MENUITEM "&Copy\tCtrl+C",               ID_EDIT_COPY
        MENUITEM "&Paste\tCtrl+V",              ID_EDIT_PASTE
        MENUITEM SEPARATOR
        MENUITEM "&Find...\tCtrl+F",            ID_EDIT_FIND
        MENUITEM "&Replace...",                 ID_EDIT_REPLACE
        MENUITEM "&Go To...\tCtrl+G",           ID_EDIT_GOTO
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About Notepad+...",          ID_APP_ABOUT
    END
#endif // _WIN32_WCE_PSPC
END

