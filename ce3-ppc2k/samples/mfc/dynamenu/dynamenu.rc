/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_ABOUTBOX DIALOGEX 0, 0, 140, 44
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CAPTIONOKBTN
CAPTION "About Dynamenu"
FONT 8, "Tahoma"
BEGIN
    ICON            IDR_MAINFRAME,IDC_STATIC,15,13,21,20
    LTEXT           "Dynamenu ",IDC_STATIC,46,13,81,8
    LTEXT           "Copyright © 2000",IDC_STATIC,46,25,87,8
END

IDD_CHANGECOLOR DIALOG DISCARDABLE  0, 0, 129, 93
STYLE DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_CAPTIONOKBTN
CAPTION "Change Color Options"
FONT 8, "Tahoma"
BEGIN
    CONTROL         "",IDC_COLOR1,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,17,5,
                    91,10
    CONTROL         "",IDC_COLOR2,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,17,
                    26,92,10
    CONTROL         "",IDC_COLOR3,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,17,
                    47,92,10
    CONTROL         "",IDC_COLOR4,"Button",BS_AUTOCHECKBOX | WS_TABSTOP,17,
                    68,91,10
END


