/////////////////////////////////////////////////////////////////////////////
//
// Menu
//
IDR_MAINFRAME MENU PRELOAD DISCARDABLE 
BEGIN
    POPUP "&File"
    BEGIN
        MENUITEM "E&xit",                       ID_APP_EXIT
    END
    POPUP "&Color"
    BEGIN
        MENUITEM SEPARATOR
        MENUITEM "Change Options...",           ID_COLOR_OPTIONS
    END
    POPUP "&Help"
    BEGIN
        MENUITEM "&About DynaMenu...",          ID_APP_ABOUT
    END
END


