Private Sub cmd3K_Click()
'Enter three of a kind
    If TurnOver = "False" Then
        Dim ThreeKTotal
        CountDups
        If isThreeKind = "True" Or isFourKind = "True" Or isYahtzee = "True" Then
            ScoreSound
            For DieNum = 0 To 4
                ThreeKTotal = ThreeKTotal + DiceVals(DieNum)
            Next
            lblP1BtmTot.Caption = lblP1BtmTot.Caption + ThreeKTotal
            lblP1Tot.Caption = lblP1Tot.Caption + ThreeKTotal
            lblP13K.Caption = ThreeKTotal
        Else
            SorrySound
            lblP13K.Caption = 0
        End If
        cmd3K.Enabled = False
        lblP13K.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub

Private Sub cmd4K_Click()
'Enter four of a kind
    If TurnOver = "False" Then
        Dim FourKTotal
        CountDups
        If isFourKind = "True" Or isYahtzee = "True" Then
            ScoreSound
            For DieNum = 0 To 4
                FourKTotal = FourKTotal + DiceVals(DieNum)
            Next
            lblP1BtmTot.Caption = lblP1BtmTot.Caption + FourKTotal
            lblP1Tot.Caption = lblP1Tot.Caption + FourKTotal
            lblP14K.Caption = FourKTotal
        Else
            SorrySound
            lblP14K.Caption = 0
        End If
        cmd4K.Enabled = False
        lblP14K.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub

Private Sub cmdSS_Click()
'Enter small straight
    If TurnOver = "False" Then
        CheckSmallStraight
        If Small = "True" Then
            ScoreSound
            lblP1SS.Caption = 30
            lblP1BtmTot.Caption = lblP1BtmTot.Caption + 30
            lblP1Tot.Caption = lblP1Tot.Caption + 30
        Else
            SorrySound
            lblP1SS.Caption = 0
        End If
        
        cmdSS.Enabled = False
        lblP1SS.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub

Private Sub cmdLS_Click()
'Enter large straight
    If TurnOver = "False" Then
        CheckLargeStraight
        If Large = "True" Then
            ScoreSound
            lblP1LS.Caption = 40
            lblP1BtmTot.Caption = lblP1BtmTot.Caption + 40
            lblP1Tot.Caption = lblP1Tot.Caption + 40
        Else
            SorrySound
            lblP1LS.Caption = 0
        End If
        
        cmdLS.Enabled = False
        lblP1LS.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub

Private Sub cmdFH_Click()
'Enter Full House
    If TurnOver = "False" Then
        CountDups
        If isTwoKind = "True" And isThreeKind = "True" Then
            ScoreSound
            lblP1FH.Caption = 25
            lblP1BtmTot.Caption = lblP1BtmTot.Caption + 25
            lblP1Tot.Caption = lblP1Tot.Caption + 25
        Else
            SorrySound
            lblP1FH.Caption = 0
        End If
        
        cmdFH.Enabled = False
        lblP1FH.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub

Private Sub cmdChance_Click()
ScoreSound
'Enter chance
    If TurnOver = "False" Then
        Dim ChanceTotal
        ChanceTotal = 0
        For DieNum = 0 To 4
            ChanceTotal = ChanceTotal + DiceVals(DieNum)
        Next
        lblP1Chance.Caption = ChanceTotal
        lblP1BtmTot.Caption = lblP1BtmTot.Caption + ChanceTotal
        lblP1Tot.Caption = lblP1Tot.Caption + ChanceTotal
        
        cmdChance.Enabled = False
        lblP1Chance.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub
Private Sub cmdSweep_Click()
'Enter sweep
    If TurnOver = "False" Then
        CountDups
        If isYahtzee = "True" Then
            ScoreSound
            lblP1Sweep.Caption = 50
            lblP1BtmTot.Caption = lblP1BtmTot.Caption + 50
            lblP1Tot.Caption = lblP1Tot.Caption + 50
        Else
            SorrySound
            lblP1Sweep.Caption = 0
        End If
        
        cmdSweep.Enabled = False
        lblP1Sweep.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub

Private Sub CheckIfDone()
    'Check to see of the game is complete based upon the CatLeft
    'variable which is decremented each time a category
    '(1's, 2's, etc.) is completed.
    Dim Over, Top, Low
    CatLeft = CatLeft - 1
    If CatLeft = 0 Then
        frmMain.Enabled = False
        Over = MsgBox("Thank you for playing, you had a score of " & lblP1Tot.Caption & ".  Would you like to play again?", vbYesNo, "Game Over")
        frmMain.Enabled = True
        If Over = vbYes Then
            mnuGameNew_Click
        Else
            App.End
        End If
    End If
End Sub
Sub RollDice()
    'Re-populates the images with new Dice bmp's if the borderstyle
    'is set to 0.  If it's set to 1, then it's been "frozen" and
    'should not be re-populated.
    If Not DieLocked(1) Then
        imgD1.Picture = ChooseBitmap
        imgD1.Tag = GetValue
        DiceVals(0) = GetValue
    End If
    If Not DieLocked(2) Then
        imgD2.Picture = ChooseBitmap
        imgD2.Tag = GetValue
        DiceVals(1) = GetValue
    End If
    If Not DieLocked(3) Then
        imgD3.Picture = ChooseBitmap
        imgD3.Tag = GetValue
        DiceVals(2) = GetValue
    End If
    If Not DieLocked(4) Then
        imgD4.Picture = ChooseBitmap
        imgD4.Tag = GetValue
        DiceVals(3) = GetValue
    End If
    If Not DieLocked(5) Then
        imgD5.Picture = ChooseBitmap
        imgD5.Tag = GetValue
        DiceVals(4) = GetValue
    End If
End Sub

'These routines set and clear the "frozen" state of the dice

