'Sets the border of a selected die
Sub SetBorder(img)
    img.DrawLine 0, 0, ImgHeight, 0, vbBlack                  'left
    img.DrawLine 0, ImgWidth, 0, 0, vbBlack                   'top
    img.DrawLine 0, ImgWidth, ImgHeight, ImgWidth, vbBlack    'right
    img.DrawLine ImgHeight, ImgWidth, ImgHeight, 0, vbBlack   'bottom
End Sub
'Clears the border of a de-selected die
Sub ClearBorder(img)
    img.DrawLine 0, 0, ImgHeight, 0, &HC0C0C0                 'left
    img.DrawLine 0, ImgWidth, 0, 0, &HC0C0C0                  'top
    img.DrawLine 0, ImgWidth, ImgHeight, ImgWidth, &HC0C0C0   'right
    img.DrawLine ImgHeight, ImgWidth, ImgHeight, 0, &HC0C0C0  'bottom
End Sub
Sub CheckBonus(sumDice)
    lblP1Tot.Caption = lblP1Tot.Caption + sumDice
    lblP1TopTot.Caption = lblP1TopTot.Caption + sumDice
    If lblP1TopTot.Caption > 62 Then
        lblP1Bonus.Caption = Bonus
        lblP1TopTot.Caption = lblP1TopTot.Caption + Bonus
        lblP1Tot.Caption = lblP1Tot.Caption + Bonus
    End If
End Sub

Sub CheckSmallStraight()
    Dim IsOne, IsTwo, IsThree, IsFour, IsFive, IsSix
    For DieNum = 0 To 4
        If DiceVals(DieNum) = 1 Then
            If IsOne = "" Then
                IsOne = "True"
            End If
        End If
        If DiceVals(DieNum) = 2 Then
            If IsTwo = "" Then
                IsTwo = "True"
            End If
        End If
        If DiceVals(DieNum) = 3 Then
            If IsThree = "" Then
                IsThree = "True"
            End If
        End If
        If DiceVals(DieNum) = 4 Then
            If IsFour = "" Then
                IsFour = "True"
            End If
        End If
        If DiceVals(DieNum) = 5 Then
            If IsFive = "" Then
                IsFive = "True"
            End If
        End If
        If DiceVals(DieNum) = 6 Then
            If IsSix = "" Then
                IsSix = "True"
            End If
        End If
    Next
    If IsOne = "True" And IsTwo = "True" And IsThree = "True" And IsFour = "True" Then
        Small = "True"
    ElseIf IsTwo = "True" And IsThree = "True" And IsFour = "True" And IsFive = "True" Then
        Small = "True"
    ElseIf IsThree = "True" And IsFour = "True" And IsFive = "True" And IsSix = "True" Then
        Small = "True"
    Else
        Small = "False"
    End If
End Sub

Sub CheckLargeStraight()
    Dim IsOne, IsTwo, IsThree, IsFour, IsFive, IsSix
    For DieNum = 0 To 4
        If DiceVals(DieNum) = 1 Then
            If IsOne = "" Then
                IsOne = "True"
            End If
        End If
        If DiceVals(DieNum) = 2 Then
            If IsTwo = "" Then
                IsTwo = "True"
            End If
        End If
        If DiceVals(DieNum) = 3 Then
            If IsThree = "" Then
                IsThree = "True"
            End If
        End If
        If DiceVals(DieNum) = 4 Then
            If IsFour = "" Then
                IsFour = "True"
            End If
        End If
        If DiceVals(DieNum) = 5 Then
            If IsFive = "" Then
                IsFive = "True"
            End If
        End If
        If DiceVals(DieNum) = 6 Then
            If IsSix = "" Then
                IsSix = "True"
            End If
        End If
    Next
    If IsOne = "True" And IsTwo = "True" And IsThree = "True" And IsFour = "True" And IsFive = "True" Then
        Large = "True"
    ElseIf IsTwo = "True" And IsThree = "True" And IsFour = "True" And IsFive = "True" And IsSix = "True" Then
        Large = "True"
    Else
        Large = "False"
    End If
End Sub
'  This sub counts duplicate dice
Sub CountDups()
    Dim OnesCount, TwosCount, ThreesCount, FoursCount, FivesCount, SixesCount
    isTwoKind = "False"
    isThreeKind = "False"
    isFourKind = "False"
    isYahtzee = "False"
    For DieNum = 0 To 4
        If DiceVals(DieNum) = 1 Then
            OnesCount = OnesCount + 1
        End If
        If DiceVals(DieNum) = 2 Then
            TwosCount = TwosCount + 1
        End If
        If DiceVals(DieNum) = 3 Then
            ThreesCount = ThreesCount + 1
        End If
        If DiceVals(DieNum) = 4 Then
            FoursCount = FoursCount + 1
        End If
        If DiceVals(DieNum) = 5 Then
            FivesCount = FivesCount + 1
        End If
        If DiceVals(DieNum) = 6 Then
            SixesCount = SixesCount + 1
        End If
    Next
    If OnesCount = 2 Or TwosCount = 2 Or ThreesCount = 2 Or FoursCount = 2 Or FivesCount = 2 Or SixesCount = 2 Then
        isTwoKind = "True"
    End If
    If OnesCount = 3 Or TwosCount = 3 Or ThreesCount = 3 Or FoursCount = 3 Or FivesCount = 3 Or SixesCount = 3 Then
        isThreeKind = "True"
    End If
    If OnesCount = 4 Or TwosCount = 4 Or ThreesCount = 4 Or FoursCount = 4 Or FivesCount = 4 Or SixesCount = 4 Then
        isFourKind = "True"
    End If
    If OnesCount = 5 Or TwosCount = 5 Or ThreesCount = 5 Or FoursCount = 5 Or FivesCount = 5 Or SixesCount = 5 Then
        isYahtzee = "True"
    End If
End Sub

