Attribute VB_Name = "frmMain"
Attribute VB_GlobalNameSpace = False
Attribute VB_Creatable = False
Attribute VB_PredeclaredId = True
Attribute VB_Exposed = False
'********************************************************************************
'*
'*  Dice - Main form code
'*
'*  Copyright (c) 1998 Microsoft Corporation

Option Explicit

Dim RollCount
Dim DiceVals(5)
Dim DieLocked(5)
Const Bonus = 35
Dim sumDice
Dim DieNum
Dim Small
Dim Large
Dim isTwoKind
Dim isThreeKind
Dim isFourKind
Dim isYahtzee
Dim TurnOver
Dim CatLeft
Dim ImgWidth
Dim ImgHeight

Private Sub cmdBar_MenuClick(ByVal Item As CommandbarLib.Item)
  Select Case Item.Key
  Case "New"
    NewGame
  Case "About"
    frmAbout.Show
  Case "Exit"
    App.End
  End Select
End Sub

Private Sub cmdRoll_Click()
    TurnOver = "False"
    'Increment the roll counter
    RollCount = RollCount + 1
    'unfreeze dice to enable selection
    imgD1.Enabled = True
    imgD2.Enabled = True
    imgD3.Enabled = True
    imgD4.Enabled = True
    imgD5.Enabled = True
    PlayWaveFile (App.Path & "rolldice.wav")
    'check for which roll we're on
    Select Case RollCount
        Case 1, 2
            cmdRoll.Caption = "Roll " & RollCount + 1
            RollDice
        Case 3
            RollDice
            cmdRoll.Caption = "Roll 1"
            cmdRoll.Enabled = False
            RollCount = 0
            Exit Sub
    End Select
End Sub

Private Sub Form_Load()
    imgD1.Top = -100
    imgD2.Top = -100
    imgD3.Top = -100
    imgD4.Top = -100
    imgD5.Top = -100
    imgD1.Top = 600
    imgD2.Top = 600
    imgD3.Top = 600
    imgD4.Top = 600
    imgD5.Top = 600
    
    cmdBar.Left = 0
    cmdBar.Top = 0
    cmdBar.Width = Me.Width

    Dim mnuMain As CommandbarLib.CommandBarMenuBar
    Dim mnuFile As CommandbarLib.Item
    
    Set mnuMain = cmdBar.Controls.Add(cbrMenuBar, "MainMenu")
    'add File menu items
    Set mnuFile = mnuMain.Items.Add(1, "File", "&File")
    mnuFile.SubItems.Add , "New", "&New"
    mnuFile.SubItems.Add , "", "", cbrMenuSeparator
    mnuFile.SubItems.Add , "About", "&About"
    mnuFile.SubItems.Add , "", "", cbrMenuSeparator
    mnuFile.SubItems.Add , "Exit", "E&xit"
    
    'initialize variables
    RollCount = 0
    CatLeft = 13
    ImgWidth = imgD1.Width
    ImgHeight = imgD1.Height
    DieLocked(1) = False
    DieLocked(2) = False
    DieLocked(3) = False
    DieLocked(4) = False
    DieLocked(5) = False
    'set totals and subtotals to zero
    lblP1Tot.Caption = 0
    lblP1TopTot.Caption = 0
    lblP1BtmTot.Caption = 0
    'set label caption
    Label2.Caption = "Click the dice to freeze them." _
        & vbCrLf & "Select the buttons below" _
        & vbCrLf & "to record your score."
    FreezeDice
End Sub

Sub ResetRoll()
    'this routine resets all necessary UI objects after
    'one turn is complete.  Note that because the Image
    'BorderStyle property contains a bug which causes the
    'bitmap to be improperly drawn, I need to use DrawLine
    'to set and clear image "borders".
    RollCount = 0
    cmdRoll.Caption = "Roll 1"
    DieLocked(1) = False
    DieLocked(2) = False
    DieLocked(3) = False
    DieLocked(4) = False
    DieLocked(5) = False
    ClearBorder imgD1
    ClearBorder imgD2
    ClearBorder imgD3
    ClearBorder imgD4
    ClearBorder imgD5
    cmdRoll.Enabled = True
    TurnOver = "True"
    FreezeDice
End Sub

Private Sub cmdOne_Click()
ScoreSound
'Enter ones
    If TurnOver = "False" Then
        sumDice = 0
        For DieNum = 0 To 4
            If DiceVals(DieNum) = 1 Then
                sumDice = sumDice + DiceVals(DieNum)
            End If
        Next
        lblP11.Caption = sumDice
        CheckBonus sumDice
        cmdOne.Enabled = False
        lblP11.BackColor = &H8000000F
        CheckIfDone
        ResetRoll
    End If
End Sub

